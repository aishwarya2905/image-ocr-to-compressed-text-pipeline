MOCK_STAGES=false
OCR_URL=http://localhost:8001
HUFFMAN_URL=http://localhost:8002

# SQLite by default — swap for postgres://user:pass@host/db in production
DATABASE_URL=sqlite:///./neuralpress.db

# Change this to a long random string in production
JWT_SECRET=change-me-in-production-use-a-long-random-string
TOKEN_EXPIRE_HOURS=72

# Shared secret that Stage 1 must send in X-Stage-Secret header to use the relay endpoint
STAGE_SECRET=internal-secret

# Directory where uploaded images are stored (per-user subdirectory)
UPLOADS_DIR=./uploads
